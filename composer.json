{
    "name": "ppl-kell-e/medislot-dusk-tests",
    "description": "Laravel Dusk Browser Tests — MediSlot (PKE-1 Pengelolaan Profil)",
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "laravel/dusk": "^8.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "dusk": "php artisan dusk"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
